# ── Database ───────────────────────────────────────────────────────────────────
# Coolify sets DATABASE_URL automatically for managed Postgres.
# If using the bundled docker-compose Postgres, only POSTGRES_PASSWORD is needed.
POSTGRES_PASSWORD=change_me

# ── Auth ───────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_32_chars_minimum
BETTER_AUTH_URL=https://api.yourdomain.com
CLIENT_URL=https://yourdomain.com
CAPTCHA_SECRET=change_me

# ── Security ───────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change_me

# ── First admin account (used once on first deploy to seed the DB) ─────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_me_strong_password

# ── HRMS integration ───────────────────────────────────────────────────────────
HRMS_API_URL=https://your-hrms-api.com/api/v1
HRMS_API_EMAIL=service@yourdomain.com
HRMS_API_PASSWORD=change_me

# ── WiseWork integration ────────────────────────────────────────────────────────
# URL of the WiseWork (HRMS-POC) backend — e.g. https://wisework-api.yourdomain.com
# Leave blank to disable ticket-assignment notifications to WiseWork
WISEWORK_NOTIFICATION_URL=
# Must match TICKET_TRACKER_API_KEY in the WiseWork backend .env
WISEWORK_NOTIFICATION_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────────
MOONSHOT_API_KEY=
SENTRY_DSN=
GMAIL_USER=
GMAIL_APP_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_SECRET=
