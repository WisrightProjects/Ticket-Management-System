{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "ESNext"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@tms/core": ["../packages/core/src/index.ts"]
    }
  },
  "include": ["./**/*.ts", "../playwright.config.ts"]
}
